{
  "name": "frontend_tk_rs",
  "version": "0.0.0",
  "description": "generate frontend APIs, TypeScript types, and UI from Swagger use Rust",
  "author": "",
  "license": "ISC",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* --filter=./crates/* build",
    "benchmark:codegen": "node scripts/benchmark/run-codegen-10k-benchmark.mjs",
    "benchmark:rust": "cargo bench -p swagger_gen --bench codegen_pipeline",
    "benchmark": "pnpm benchmark:codegen && pnpm benchmark:rust",
    "binding:version": "node scripts/release/set-binding-version.mjs",
    "binding:version:check": "node scripts/release/set-binding-version.mjs --check"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8"
  }
}
